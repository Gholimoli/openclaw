# Coder sandbox image: includes the CLIs needed for /work workflows.
#
# Base: openclaw-sandbox-common (ships with Node/npm/pnpm/bun/brew and common build tools)
# This image is intentionally "batteries included" to avoid runtime installs in locked-down sandboxes.
#
# Build (on VPS):
#   docker build -t openclaw-sandbox-coder:bookworm -f ops/vps/Dockerfile.openclaw-sandbox-coder .

ARG BASE_IMAGE=openclaw-sandbox-common:bookworm-slim
FROM ${BASE_IMAGE}

USER root

ENV DEBIAN_FRONTEND=noninteractive

# GitHub CLI + core tooling
RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    gh \
    openssh-client \
    ca-certificates \
    curl \
    gnupg \
    python3 \
    python3-venv \
    pipx \
  && rm -rf /var/lib/apt/lists/*

# Google Cloud CLI (official Google CLI).
RUN install -m 0755 -d /etc/apt/keyrings \
  && curl -fsSL https://packages.cloud.google.com/apt/doc/apt-key.gpg \
    | gpg --dearmor -o /etc/apt/keyrings/google-cloud-cli.gpg \
  && chmod a+r /etc/apt/keyrings/google-cloud-cli.gpg \
  && echo "deb [signed-by=/etc/apt/keyrings/google-cloud-cli.gpg] https://packages.cloud.google.com/apt cloud-sdk main" \
    > /etc/apt/sources.list.d/google-cloud-cli.list \
  && apt-get update \
  && apt-get install -y --no-install-recommends google-cloud-cli \
  && rm -rf /var/lib/apt/lists/*

# Install coding CLIs.
# Notes:
# - Keep these pinned in production (exact versions) once you settle on a known-good set.
# - This Dockerfile uses npm for portability.
RUN npm install -g \
  @openai/codex \
  @google/gemini-cli \
  && npm cache clean --force

# Cursor Agent installs per-user under ~/.local/bin. Install it for the sandbox user
# and expose stable symlinks on PATH.
RUN su sandbox -c 'export HOME=/home/sandbox PATH="$HOME/.local/bin:$PATH"; curl -fsSL https://cursor.com/install | bash' \
  && ln -sf /home/sandbox/.local/bin/agent /usr/local/bin/agent \
  && ln -sf /home/sandbox/.local/bin/cursor-agent /usr/local/bin/cursor-agent

# x-cli currently installs from source. Use pipx for an isolated Python tool install.
RUN pipx install "git+https://github.com/INFATOSHI/x-cli.git" \
  && ln -sf /root/.local/bin/x-cli /usr/local/bin/x-cli

# Seed permissive coding-agent defaults inside the sandbox. OpenClaw approvals still
# apply outside this container; these defaults only affect the nested coding CLIs.
RUN install -d -m 0755 /home/sandbox/.codex /home/sandbox/.gemini/policies \
  && printf 'approval_policy = "never"\nsandbox_mode = "danger-full-access"\n' \
    > /home/sandbox/.codex/config.toml \
  && printf '[[rule]]\ntoolName = "*"\ndecision = "allow"\npriority = 1000\n' \
    > /home/sandbox/.gemini/policies/openclaw-yolo.toml \
  && printf '#!/usr/bin/env bash\nset -euo pipefail\nexec gemini --approval-mode yolo "$@"\n' \
    > /usr/local/bin/gemini-yolo \
  && chmod +x /usr/local/bin/gemini-yolo \
  && printf '#!/usr/bin/env bash\nset -euo pipefail\nexec agent --force "$@"\n' \
    > /usr/local/bin/agent-full \
  && chmod +x /usr/local/bin/agent-full \
  && ln -sf /usr/local/bin/agent-full /usr/local/bin/cursor-agent-full \
  && chown -R sandbox:sandbox /home/sandbox/.codex /home/sandbox/.gemini

# Optional: summarize (compact diffs/logs into fix lists).
# This is installed via Homebrew because the official distribution is shipped as a brew formula.
# If you don't need it, remove this block to speed up builds.
RUN brew install steipete/tap/summarize \
  && (command -v summarize >/dev/null 2>&1 || (echo "summarize not on PATH after install" >&2 && exit 1))

# CodeRabbit CLI (install script)
RUN curl -fsSL https://cli.coderabbit.ai/install.sh | sh \
  && (command -v coderabbit >/dev/null 2>&1 || (echo "coderabbit not on PATH after install" >&2 && exit 1)) \
  && CODERABBIT_BIN="$(command -v coderabbit)" \
  && cp "$CODERABBIT_BIN" /usr/local/bin/coderabbit \
  && chmod +x /usr/local/bin/coderabbit \
  && /usr/local/bin/coderabbit --version >/dev/null 2>&1 || true

USER sandbox
WORKDIR /home/sandbox

CMD ["sleep", "infinity"]
