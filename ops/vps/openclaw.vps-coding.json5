// Secure VPS config focused on deterministic coding automation.
// Location: ~/.openclaw/openclaw.json (or $OPENCLAW_STATE_DIR/openclaw.json)
{
  // Keep the gateway private. Use Tailscale to access the Control UI.
  gateway: {
    mode: "local",
    bind: "loopback", // do not expose publicly
    port: 18789,
    auth: {
      mode: "token",
      token: "${OPENCLAW_GATEWAY_TOKEN}",
    },
    // Harden /tools/invoke: keep the default hard-deny list and add more.
    tools: {
      deny: ["gateway", "sessions_send", "sessions_spawn", "whatsapp_login"],
    },
  },

  // Environment: put secrets in ~/.openclaw/.env so the daemon can read them.
  env: {
    // Optional: import missing vars from login shell (useful on VPS if you manage env in ~/.profile).
    shellEnv: { enabled: false },
    // GitHub access should come from a GitHub App installation, not a broad personal PAT.
    // The /work pipeline mints a short-lived installation token and injects it into coder jobs.
    // Required env vars:
    //   GITHUB_APP_ID
    //   GITHUB_APP_INSTALLATION_ID
    //   GITHUB_APP_PRIVATE_KEY or GITHUB_APP_PRIVATE_KEY_FILE
  },

  // Telegram: owner-allowlisted DMs, optional dedicated agent groups, and block channel-initiated config writes.
  channels: {
    telegram: {
      enabled: true,
      botToken: "${TELEGRAM_BOT_TOKEN}",
      capabilities: {
        // Keep Telegram menus on inline keyboards so approvals and agent choices
        // work the same way in DMs and dedicated groups.
        inlineButtons: "allowlist",
      },
      // For single-operator setups, prefer allowlisting your numeric Telegram user ID.
      // This avoids pairing-code friction while keeping DMs locked down.
      // Find your ID by messaging the bot once, then check:
      //   openclaw channels status --probe
      dmPolicy: "allowlist",
      allowFrom: ["${TELEGRAM_OWNER_ID}"],
      // If you later add dedicated worker groups, keep them sender-restricted to the owner.
      groupPolicy: "allowlist",
      groupAllowFrom: ["${TELEGRAM_OWNER_ID}"],
      // Optional phase-two client chat takeover lanes.
      // Keep these absent until you explicitly allowlist a client chat.
      // clients: {
      //   "123456789": {
      //     label: "Acme client DM",
      //     defaultAgentId: "main",
      //     allowedAgents: ["main", "coder", "devops"],
      //     orchestration: {
      //       enabled: true,
      //       peerAgents: ["coder", "devops"],
      //       peerReplyPolicy: "addressed",
      //       historyLimit: 40,
      //       strategy: "sequential",
      //       includeAgentReplies: true,
      //     },
      //   },
      // },
      configWrites: false,
      // Never stream partial drafts to Telegram. Only send final replies.
      streamMode: "off",
    },
  },

  // Optional Telegram worker swarms. These keep per-agent sessions isolated
  // while sharing a bounded room-visible log in the same Telegram room.
  // broadcast: {
  //   strategy: "sequential",
  //   "-1004444444444": ["main", "coder", "devops"],
  //   "-1004444444444:topic:42": ["main", "power"],
  // },

  // Secure DM mode so multi-user accidents don't cross-contaminate context.
  session: {
    dmScope: "per-channel-peer",
  },

  // Enable bundled plugins explicitly.
  plugins: {
    // Production path: use the bundled work plugin from the live OpenClaw
    // runtime (for this VPS pack, ~/openclaw-current). Do not add
    // plugins.load.paths for work here.
    entries: {
      "google-gemini-cli-auth": {
        enabled: true,
      },
      work: {
        enabled: true,
        config: {
          // Prefer absolute lobsterPath in production (reduces PATH hijack risk).
          // Ubuntu bootstrap installs @clawdbot/lobster at /usr/bin/lobster.
          // lobsterPath: "/usr/bin/lobster",
          workRoot: "~/work/repos",
          defaultBase: "main",
          coderSessionKey: "agent:coder:main",
          maxFixLoops: 3,
          timeoutMs: 1800000, // 30m
        },
      },
    },
  },

  // Global tool baseline: keep it tight; let the workflow run tools via /tools/invoke
  // against the coder agent session, not your main chat surface.
  tools: {
    profile: "minimal",
    elevated: { enabled: false },
    // Speech-to-text: enable audio transcription for inbound voice notes.
    // The VPS preset keeps this local-only to avoid OpenAI API-key usage.
    media: {
      audio: {
        enabled: true,
        maxBytes: 20971520, // 20MB
        timeoutSeconds: 120,
        models: [
          // Local Whisper.cpp (install whisper-cli and set WHISPER_CPP_MODEL in ~/.openclaw/.env)
          {
            type: "cli",
            command: "whisper-cli",
            args: [
              "-m",
              "${WHISPER_CPP_MODEL}",
              "-otxt",
              "-of",
              "{{OutputBase}}",
              "-np",
              "-nt",
              "{{MediaPath}}",
            ],
          },
        ],
      },
    },
  },

  agents: {
    list: [
      {
        id: "main",
        agentDir: "~/.openclaw/agents/main/agent",
        model: {
          primary: "openai-codex/gpt-5.3-codex",
          fallbacks: ["openai/gpt-5.4", "google/gemini-3-pro-preview"],
        },
        workspace: "~/work/repos",
        identity: {
          name: "Ted",
          emoji: "🧭",
          theme: "operator",
        },
        // Ted owns research, repo intake, and orchestration.
        // Ted host execution stays approval-gated and should prefer dispatch into the power lane.
        // Nested coding CLIs inside the coder sandbox manage their own permissive agent modes.
        subagents: { allowAgents: ["coder", "power", "devops"] },
        tools: {
          profile: "minimal",
          alsoAllow: ["read", "exec", "process"],
          deny: [
            "browser",
            "write",
            "edit",
            "apply_patch",
            "canvas",
            "nodes",
            "cron",
            "gateway",
            "sessions_spawn",
            "sessions_send",
          ],
        },
      },
      {
        id: "coder",
        agentDir: "~/.openclaw/agents/coder/agent",
        model: {
          primary: "openai-codex/gpt-5.3-codex",
          fallbacks: ["openai/gpt-5.4", "google/gemini-3-pro-preview"],
        },
        workspace: "~/work/repos",
        // Run all tool execution for this agent in Docker.
        sandbox: {
          mode: "all",
          scope: "agent",
          workspaceAccess: "rw",
          docker: {
            image: "openclaw-sandbox-coder:bookworm",
            network: "bridge",
            readOnlyRoot: false,
            // Run as the same uid/gid as the host service user so mounted repos
            // and bound OAuth dirs stay writable.
            user: "${OPENCLAW_SANDBOX_UID}:${OPENCLAW_SANDBOX_GID}",
            env: {
              LANG: "C.UTF-8",
              // Auth for CLI tools inside the sandbox:
              // - GitHub access is injected at runtime by the /work pipeline.
              // - Codex, Gemini, and Railway CLI state is bind-mounted from the host.
              // - Optional Google/X credentials remain available for supporting CLIs.
              GCLOUD_PROJECT: "${GCLOUD_PROJECT}",
              GOOGLE_APPLICATION_CREDENTIALS: "${GCLOUD_SERVICE_ACCOUNT_KEY_FILE}",
              RAILWAY_API_TOKEN: "${RAILWAY_API_TOKEN}",
              X_API_KEY: "${X_API_KEY}",
              X_API_SECRET: "${X_API_SECRET}",
              X_BEARER_TOKEN: "${X_BEARER_TOKEN}",
              X_ACCESS_TOKEN: "${X_ACCESS_TOKEN}",
              X_ACCESS_TOKEN_SECRET: "${X_ACCESS_TOKEN_SECRET}",
              CODERABBIT_API_KEY: "${CODERABBIT_API_KEY}",
              // Git identity (required for commits):
              GIT_AUTHOR_NAME: "${GIT_AUTHOR_NAME}",
              GIT_AUTHOR_EMAIL: "${GIT_AUTHOR_EMAIL}",
              GIT_COMMITTER_NAME: "${GIT_AUTHOR_NAME}",
              GIT_COMMITTER_EMAIL: "${GIT_AUTHOR_EMAIL}",
            },
            binds: [
              "${HOME}/.codex:/home/sandbox/.codex",
              "${HOME}/.gemini:/home/sandbox/.gemini",
              "${HOME}/.railway:/home/sandbox/.railway",
            ],
            // Keep sandbox bounded.
            pidsLimit: 256,
            memory: "4g",
            cpus: 2,
          },
        },
        // Allow only what the workflow needs inside sandbox.
        tools: {
          profile: "minimal",
          allow: ["exec", "process", "read", "write", "edit", "apply_patch"],
          deny: [
            "browser",
            "canvas",
            "nodes",
            "cron",
            "gateway",
            "sessions_spawn",
            "sessions_send",
          ],
        },
      },
      {
        // "Super powers" agent: browser + direct host access for repo + VPS tasks.
        // This lane is intentionally capable of code edits, apply_patch, and unrestricted host exec.
        // Keep it owner-only and full-auto, but require operator consultation before big-risk actions.
        id: "power",
        agentDir: "~/.openclaw/agents/power/agent",
        model: {
          primary: "openai-codex/gpt-5.3-codex",
          fallbacks: ["openai/gpt-5.4", "google/gemini-3-pro-preview"],
        },
        workspace: "~/work/repos",
        systemPrompt: "Consult the operator before deploys, restarts, service control, git push/merge/rebase/reset/branch deletion/tagging/force operations, publish/release steps, secret/token/env/live-config changes, destructive file/data operations, or other external side effects that could break production or leak data.",
        tools: {
          profile: "full",
          allow: ["browser", "exec", "process", "read", "write", "edit", "apply_patch"],
          deny: ["canvas", "nodes", "cron", "gateway", "sessions_spawn", "sessions_send"],
          exec: {
            host: "gateway",
            security: "full",
            ask: "off",
            applyPatch: {
              enabled: true,
              workspaceOnly: false,
            },
          },
          fs: {
            workspaceOnly: false,
          },
        },
      },
      {
        id: "devops",
        agentDir: "~/.openclaw/agents/devops/agent",
        model: {
          primary: "openai-codex/gpt-5.3-codex",
          fallbacks: ["openai/gpt-5.4", "google/gemini-3-pro-preview"],
        },
        workspace: "~/.openclaw/workspace/devops",
        tools: { profile: "minimal", deny: ["exec", "process"] },
      },
    ],
  },

  // Add Telegram group bindings only after you have real private group IDs.
  bindings: [],

  // Forward exec approvals to your Telegram DM for approval-gated agents.
  // Telegram should render tap-first inline menus; /approve remains a fallback.
  approvals: {
    exec: {
      enabled: true,
      mode: "both",
      agentFilter: ["main"],
      targets: [{ channel: "telegram", to: "${TELEGRAM_OWNER_ID}" }],
    },
  },
}
